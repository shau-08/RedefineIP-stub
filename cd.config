# Controls what `make rtl-dispatch` (called by CD) actually runs.
# This repo has two RTL targets:
#   rtl    -- redefine.rtlLazyMain      (default release build)
#   synrtl -- redefine.synthRtlLazyMain (synthesis-oriented variant)
# Switch RTL_TARGET below to change which one CD builds, without
# touching any .github/workflows/*.yml file.

RTL_TARGET = rtl
TARGET = RedefineIP
